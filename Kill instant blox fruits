-- ===== LÓGICA DE VERIFICACIÓN =====
local scriptHubLoaded = false

local function startScriptHub()
    if scriptHubLoaded then return end -- Evitar cargar dos veces
    scriptHubLoaded = true
    
    -- Eliminar la pantalla de verificación con un pequeño delay para el efecto
    task.delay(0.5, function()
        blackScreen:Destroy()
    end)
    
    -- Marcar la key como reclamada globalmente
    _G.KEY_VIP_CLAIMED = true
    
    -- ===== GUI DEL SCRIPT HUB =====
    local gui = Instance.new("ScreenGui", game.CoreGui)
    gui.ResetOnSpawn = false
    gui.Name = "NPCScriptHub"
    gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    
    local main = Instance.new("Frame", gui)
    main.Size = UDim2.new(0, 360, 0, 360)
    main.Position = UDim2.new(0.3, 0, 0.3, 0)
    main.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
    main.Active = true
    main.Draggable = true
    main.ZIndex = 1
    
    -- ARCOÍRIS EN EL BORDE DEL MAIN
    local rainbowStroke = Instance.new("UIStroke", main)
    rainbowStroke.Thickness = 3
    rainbowStroke.LineJoinMode = Enum.LineJoinMode.Round
    rainbowStroke.ZIndex = 2
    
    -- Animación arcoíris para el borde
    local hue = 0
    game:GetService("RunService").RenderStepped:Connect(function(deltaTime)
        hue = (hue + deltaTime * 0.5) % 1
        rainbowStroke.Color = Color3.fromHSV(hue, 1, 1)
    end)
    
    Instance.new("UICorner", main).CornerRadius = UDim.new(0, 10)
    
    -- ===== TÍTULO NEÓN =====
    local title = Instance.new("TextLabel", main)
    title.Size = UDim2.new(1, 0, 0, 34)
    title.Text = "NPC SCRIPT HUB"
    title.TextScaled = true
    title.TextColor3 = Color3.new(1, 1, 1)
    title.BackgroundColor3 = Color3.fromRGB(55, 55, 55)
    title.ZIndex = 3
    Instance.new("UICorner", title).CornerRadius = UDim.new(0, 8)
    
    -- Efecto neón en el texto
    local neonStroke = Instance.new("UIStroke", title)
    neonStroke.Thickness = 2
    neonStroke.LineJoinMode = Enum.LineJoinMode.Round
    neonStroke.ZIndex = 4
    
    -- Animación neón para el título
    local neonHue2 = 0
    game:GetService("RunService").RenderStepped:Connect(function(deltaTime)
        neonHue2 = (neonHue2 + deltaTime * 1.2) % 1
        neonStroke.Color = Color3.fromHSV(neonHue2, 1, 1)
        neonStroke.Thickness = 2 + math.sin(tick() * 3) * 1
    end)
    
    -- ☃️ TOGGLE
    local toggle = Instance.new("TextButton", gui)
    toggle.Text = "☃️"
    toggle.Size = UDim2.new(0, 50, 0, 50)
    toggle.Position = UDim2.new(0.05, 0, 0.35, 0)
    toggle.TextScaled = true
    toggle.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
    toggle.ZIndex = 10
    Instance.new("UICorner", toggle)
    
    -- Arcoíris en el toggle
    local toggleStroke = Instance.new("UIStroke", toggle)
    toggleStroke.Thickness = 2
    toggleStroke.ZIndex = 11
    game:GetService("RunService").RenderStepped:Connect(function(deltaTime)
        local tHue = (hue + 0.5) % 1
        toggleStroke.Color = Color3.fromHSV(tHue, 1, 1)
    end)
    
    local opened = true
    toggle.MouseButton1Click:Connect(function()
        opened = not opened
        main.Visible = opened
    end)
    
    -- TARGET
    local targetNPC
    local targetLabel = Instance.new("TextLabel", main)
    targetLabel.Position = UDim2.new(0, 10, 0, 44)
    targetLabel.Size = UDim2.new(1, -20, 0, 30)
    targetLabel.Text = "TARGET: none"
    targetLabel.TextScaled = true
    targetLabel.TextColor3 = Color3.new(1, 1, 1)
    targetLabel.BackgroundColor3 = Color3.fromRGB(70, 70, 70)
    targetLabel.ZIndex = 3
    Instance.new("UICorner", targetLabel)
    
    local function isNPC(m)
        return m:IsA("Model")
        and m:FindFirstChildOfClass("Humanoid")
        and m ~= player.Character
    end
    
    mouse.Button1Down:Connect(function()
        if mouse.Target then
            local m = mouse.Target:FindFirstAncestorOfClass("Model")
            if m and isNPC(m) then
                targetNPC = m
                targetLabel.Text = "TARGET: " .. m.Name
            end
        end
    end)
    
    -- ===== BUTTON MAKER =====
    local function btn(text, y)
        local b = Instance.new("TextButton", main)
        b.Size = UDim2.new(1, -20, 0, 36)
        b.Position = UDim2.new(0, 10, 0, y)
        b.Text = text
        b.TextScaled = true
        b.BackgroundColor3 = Color3.fromRGB(75, 75, 75)
        b.TextColor3 = Color3.new(1, 1, 1)
        b.ZIndex = 3
        Instance.new("UICorner", b).CornerRadius = UDim.new(0, 6)
        
        -- Arcoíris en cada botón
        local btnStroke = Instance.new("UIStroke", b)
        btnStroke.Thickness = 1.5
        btnStroke.ZIndex = 4
        local btnOffset = y * 0.01
        game:GetService("RunService").RenderStepped:Connect(function(deltaTime)
            local bHue = (hue + btnOffset) % 1
            btnStroke.Color = Color3.fromHSV(bHue, 1, 1)
        end)
        
        return b
    end
    
    -- ===== LONG RANGE KILL =====
    local function remoteKill(npc)
        if not npc then return end
        local hum = npc:FindFirstChildOfClass("Humanoid")
        local hrp = npc:FindFirstChild("HumanoidRootPart")
        local char = player.Character
        if not hum or not hrp or not char then return end
        
        local myHRP = char:FindFirstChild("HumanoidRootPart")
        if not myHRP then return end
        
        local oldCF = hrp.CFrame
        hrp.CFrame = myHRP.CFrame * CFrame.new(0, 0, -3)
        RunService.Heartbeat:Wait()
        hum.Health = 0
        hum:TakeDamage(9e9)
        task.delay(0.05, function()
            if hrp then hrp.CFrame = oldCF end
        end)
    end
    
    -- ===== BRING LONG RANGE =====
    local bringOn = false
    RunService.Heartbeat:Connect(function()
        if bringOn and targetNPC
        and targetNPC:FindFirstChild("HumanoidRootPart")
        and player.Character
        and player.Character:FindFirstChild("HumanoidRootPart") then
            
            targetNPC.HumanoidRootPart.CFrame =
            player.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, -4)
            
            targetNPC.HumanoidRootPart.AssemblyLinearVelocity = Vector3.zero
        end
    end)
    
    -- ===== FREEZE REAL (ANTI IA) =====
    local frozen = {}
    
    local function hardFreeze(npc, state)
        if not npc then return end
        local hum = npc:FindFirstChildOfClass("Humanoid")
        local hrp = npc:FindFirstChild("HumanoidRootPart")
        if not hum or not hrp then return end
        
        if state then
            frozen[npc] = {
                Anchored = hrp.Anchored,
                AutoRotate = hum.AutoRotate
            }
            
            hrp.Anchored = true
            hum.AutoRotate = false
            
            for _, s in ipairs(Enum.HumanoidStateType:GetEnumItems()) do
                hum:SetStateEnabled(s, false)
            end
            
            hum:ChangeState(Enum.HumanoidStateType.Physics)
        else
            local data = frozen[npc]
            if data then
                hrp.Anchored = data.Anchored
                hum.AutoRotate = data.AutoRotate
                
                for _, s in ipairs(Enum.HumanoidStateType:GetEnumItems()) do
                    hum:SetStateEnabled(s, true)
                end
            end
            frozen[npc] = nil
        end
    end
    
    -- ===== BUTTONS =====
    btn("💀 KILL NPC (LONG RANGE)", 90).MouseButton1Click:Connect(function()
        if targetNPC then remoteKill(targetNPC) end
    end)
    
    btn("💀💀 KILL ALL (LONG RANGE)", 130).MouseButton1Click:Connect(function()
        if not targetNPC then return end
        for _, m in ipairs(workspace:GetDescendants()) do
            if isNPC(m) and m.Name == targetNPC.Name then
                remoteKill(m)
            end
        end
    end)
    
    btn("🧲 BRING NPC ON / OFF", 170).MouseButton1Click:Connect(function()
        bringOn = not bringOn
    end)
    
    local freezeOn = false
    btn("❄️ FREEZE NPC ON / OFF", 210).MouseButton1Click:Connect(function()
        if not targetNPC then return end
        freezeOn = not freezeOn
        hardFreeze(targetNPC, freezeOn)
    end)
    
    local freezeAllOn = false
    btn("❄️ FREEZE ALL NPC ON / OFF", 250).MouseButton1Click:Connect(function()
        freezeAllOn = not freezeAllOn
        for _, m in ipairs(workspace:GetDescendants()) do
            if isNPC(m) then
                hardFreeze(m, freezeAllOn)
            end
        end
    end)
    
    print("✅ NPC SCRIPT HUB CARGADO | FREEZE REAL + LONG RANGE")
end

-- ===== FUNCIONALIDAD DEL BOTÓN DE VERIFICACIÓN =====
local function verificarKey()
    local inputKey = textBox.Text
    
    if keyClaimed then
        statusLabel.Text = "⚠️ KEY YA RECLAMADA"
        statusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
        textBox.Text = ""
    elseif inputKey == KEY_VIP then
        statusLabel.Text = "✅ KEY CORRECTA!"
        statusLabel.TextColor3 = Color3.fromRGB(80, 255, 80)
        
        -- Efecto de destello verde en el cuadro
        boxStroke.Color = Color3.fromRGB(80, 255, 80)
        boxStroke.Thickness = 6
        
        -- Pequeña pausa para mostrar el mensaje de éxito
        task.delay(0.8, function()
            startScriptHub()
        end)
    else
        statusLabel.Text = "❌ KEY INCORRECTA"
        statusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
        textBox.Text = ""
        
        -- Efecto de error (parpadeo rojo)
        boxStroke.Color = Color3.fromRGB(255, 80, 80)
        boxStroke.Thickness = 6
        task.delay(0.3, function()
            if blackScreen and blackScreen.Parent then
                boxStroke.Color = Color3.fromHSV(neonHue, 1, 1)
            end
        end)
    end
end

verifyBtn.MouseButton1Click:Connect(verificarKey)

-- También permitir presionar Enter en el TextBox
textBox.FocusLost:Connect(function(enterPressed)
    if enterPressed then
        verificarKey()
    end
end)

